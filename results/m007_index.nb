Cell["Precomputed refined index table", "Subsection"],
Cell[BoxData["(* Precomputed series table: 13 entries, Nmax = 4 *)\nim007RefTable = <|\n  {-2, -2} -> (q^2 \\[Eta][0] + q^2 \\[Eta][0]^2),\n  {-2, -1} -> (q^2 \\[Eta][0]),\n  {-2, 0} -> (q^2),\n  {-2, 1} -> (q^2 \\[Eta][0]^(-1)),\n  {-2, 2} -> (q^2 \\[Eta][0]^(-1) + q^2),\n  {0, -1} -> (-q - q \\[Eta][0] - q^2 \\[Eta][0]),\n  {0, 0} -> (1 - 2 q - q \\[Eta][0] + q^2 \\[Eta][0]^(-1) - 2 q^2 - q^2 \\[Eta][0]),\n  {0, 1} -> (-q - q \\[Eta][0] - q^2 \\[Eta][0]),\n  {2, -2} -> (q^2 \\[Eta][0]^(-1) + q^2),\n  {2, -1} -> (q^2 \\[Eta][0]^(-1)),\n  {2, 0} -> (q^2),\n  {2, 1} -> (q^2 \\[Eta][0]),\n  {2, 2} -> (q^2 \\[Eta][0] + q^2 \\[Eta][0]^2)\n|>;"], "Input"],
Cell["Lookup function   im007ref[m, e]", "Subsection"],
Cell[BoxData["qOrder = 4;\nim007ref[m_Integer, e_Integer] :=\n  With[{raw = Lookup[im007RefTable, Key[{m, e}], Missing[\"NotComputed\"]]},\n    If[MissingQ[raw], raw,\n      Series[raw, {q, 0, qOrder}] // ExpandAll]];"], "Input"],
Cell["Usage", "Subsection"],
Cell[BoxData["(* Usage: evaluate the refined index at a given (m, e) *)\nim007ref[0, 0]\nKeys[im007RefTable]   (* list all precomputed (m,e) pairs *)"], "Input"]
