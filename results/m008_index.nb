Cell[BoxData["(* Precomputed series table: 9 entries, Nmax = 4 *)\nim008RefTable = <|\n  {-4, 2} -> (q \\[Eta][0]^-2 \\[Eta][1]^2 - q^2 \\[Eta][0]^-2 \\[Eta][1]^2),\n  {-2, 0} -> (q^2 \\[Eta][0]^-4 \\[Eta][1]),\n  {-2, 1} -> (-q^(1/2) \\[Eta][0]^(-1) \\[Eta][1] + q^(3/2) \\[Eta][0]^(-1) \\[Eta][1]),\n  {-2, 2} -> (q \\[Eta][0] - q^2 \\[Eta][0] + q^2 \\[Eta][0] \\[Eta][1]),\n  {0, -1} -> (-q^(3/2) \\[Eta][0]^-3 - q^(3/2) \\[Eta][0]^-2 + q^(3/2) \\[Eta][0]^(-1) \\[Eta][1]^(-1) - q^(3/2) \\[Eta][0]^(-1)),\n  {0, 0} -> (1 - q \\[Eta][0]^(-1) - 3 q - q \\[Eta][0] \\[Eta][1] + q^2 \\[Eta][0]^-2 \\[Eta][1]^(-1) + q^2 \\[Eta][0]^(-1) \\[Eta][1]^(-1) - q^2 \\[Eta][0]^(-1) + q^2 \\[Eta][1]^(-1) - 3 q^2 - q^2 \\[Eta][1] + q^2 \\[Eta][0] - q^2 \\[Eta][0] \\[Eta][1]),\n  {2, -2} -> (1 + q \\[Eta][0]^(-1) + q \\[Eta][1] - q^2 \\[Eta][0]^-3 \\[Eta][1]^(-1) - q^2 \\[Eta][0]^-2 \\[Eta][1]^(-1) - q^2 \\[Eta][0]^(-1) \\[Eta][1]^(-1) + q^2 \\[Eta][0]^(-1) - 3 q^2 + q^2 \\[Eta][1] - q^2 \\[Eta][0] \\[Eta][1]),\n  {2, -1} -> (-q^(1/2) \\[Eta][0]^(-1) \\[Eta][1]^(-1) + q^(3/2) \\[Eta][0]^(-1) \\[Eta][1]^(-1) - q^(3/2) - q^(3/2) \\[Eta][0]),\n  {4, -2} -> (q \\[Eta][0]^-2 \\[Eta][1]^-2 - q^2 \\[Eta][0]^-2 \\[Eta][1]^-2 + q^2 \\[Eta][1]^(-1))\n|>;"], "Input"],
Cell["Lookup function   im008ref[m, e]", "Subsection"],
Cell[BoxData["qOrder = 4;\nim008ref[m_Integer, e_Integer] :=\n  With[{raw = Lookup[im008RefTable, Key[{m, e}], Missing[\"NotComputed\"]]},\n    If[MissingQ[raw], raw,\n      Series[raw, {q, 0, qOrder}] // ExpandAll]];"], "Input"],
